*.swp

# Internal dev docs (gitignored anyway, but be explicit)
devdocs/

# Compose files referencing local paths
docker-compose.override.yml
.env
.env.*
!.env.example

# Existing static build (we rebuild from source in the image)
fmriflow/server/static
